{
  "name": "cloudflare-video-cdn",
  "version": "1.0.0",
  "description": "A CDN service for streaming videos using Cloudflare Workers.",
  "main": "src/worker.ts",
  "scripts": {
    "build": "tsc",
    "start": "wrangler dev",
    "dev:host": "wrangler dev --host 0.0.0.0",
    "deploy": "wrangler publish",
    "prod:start": "node server/index.js",
    "docker:build:prod": "docker build -f Dockerfile.prod -t cloudflare-video-cdn:prod ."
  },
  "dependencies": {
    "@cloudflare/workers-types": "^3.0.0",
    "express": "^4.18.2",
    "got": "^12.0.0"
  },
  "devDependencies": {
    "typescript": "^4.5.0",
    "wrangler": "^4.69.0"
  },
  "keywords": [
    "cloudflare",
    "cdn",
    "video",
    "streaming"
  ],
  "author": "Your Name",
  "license": "MIT"
}